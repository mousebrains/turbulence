# Data files (large)
MR/
VMP/
AtomixData
benchmarks/

# Per-cruise data directories — only the YAML config is tracked.
ARCTERX/*
!ARCTERX/perturb.yaml

# Rockland ODAS MATLAB reference (third-party)
odas/

# Reference papers (large PDFs; the README indexes ARE tracked — an ignored
# DIRECTORY is never descended into, hence the ** + unignore pattern)
papers/**
!papers/**/
!papers/**/README.md

# macOS
.DS_Store

# Python
__pycache__/
*.py[cod]
*.egg-info/
*.egg
dist/
build/
*.so

# Testing / IDE
.pytest_cache/
.benchmarks/
.coverage
htmlcov/

# Environment
.env
.venv/

# Claude Code
.claude/

# Local run artifacts and example data (large; not tracked)
examples/*/tpw/
myout/
results/
