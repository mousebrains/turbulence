version: 0.3.0
date-released: 2026-07-14
license: GPL-3.0-or-later
repository-code: "https://github.com/mousebrains/turbulence"
url: "https://github.com/mousebrains/turbulence"
keywords:
  - oceanography
  - turbulence
  - microstructure
  - dissipation
  - Rockland Scientific
  - VMP
  - MicroRider
